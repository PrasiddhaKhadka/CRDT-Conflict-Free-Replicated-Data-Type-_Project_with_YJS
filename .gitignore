# =========================

# Node.js Backend .gitignore

# =========================

# Dependencies

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables (VERY IMPORTANT)

.env
.env.*
!.env.example

# Logs

logs/
*.log

# Runtime data

pids/
*.pid
*.seed
*.pid.lock

# Coverage reports

coverage/

# Build / output folders

dist/
build/
out/

# OS generated files

.DS_Store
Thumbs.db

# IDE / Editor folders

.vscode/
.idea/
*.swp
*.swo

# Temporary files

tmp/
temp/

# Cache

.cache/
.parcel-cache/

# Optional: uploads (if your app stores files locally)

uploads/
public/uploads/

# Optional: database files (if using SQLite or similar)

*.sqlite
*.sqlite3
*.db

# Optional: Docker

docker-compose.override.yml

# Optional: testing

jest.config.js
coverage-final.json

# Optional: secrets

secrets.json
*.pem
*.key

# Optional: lock files (choose based on your package manager)

# Uncomment ONLY ONE based on your setup

# package-lock.json

# yarn.lock

# pnpm-lock.yaml

# Optional: misc

*.tgz
.env.local
.env.development.local
.env.test.local
.env.production.local
